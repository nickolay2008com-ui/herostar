# Core
NODE_ENV=production
PORT=3000
APP_URL=https://herostar.up.railway.app
SESSION_SECRET=replace-with-a-long-random-string

# OpenAI
OPENAI_API_KEY=
# Быстрый последующий диалог
OPENAI_MODEL=gpt-5.6-terra
OPENAI_REASONING_DIALOG=low
# Первый глубокий разбор ситуации
OPENAI_MODEL_DEEP=gpt-5.6-sol
OPENAI_REASONING_DEEP=medium

# Telegram Login Widget
TELEGRAM_BOT_TOKEN=
# Можно оставить пустым: приложение определит username по токену через getMe.
# Если задаёте вручную — без @, например HeroStarBot.
TELEGRAM_BOT_USERNAME=
# Предпочтительно: один числовой Telegram ID или несколько через запятую.
TELEGRAM_ADMIN_IDS=
# Дополнительно можно указать username: ainicki, @ainicki или https://t.me/ainicki.
TELEGRAM_ADMIN_USERNAMES=

# Юридические реквизиты. В production без ФИО и ОГРНИП оплата не включается.
LEGAL_FULL_NAME=
LEGAL_OGRNIP=
LEGAL_INN=
LEGAL_ADDRESS=

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
FULL_MAP_PRICE=990.00
# Звёздный клон: разовые программы без автопродления
CLONE_DAY_PRICE=499
CLONE_ALIGNMENT_PRICE=1499
CLONE_ALIGNMENT_UPGRADE_PRICE=1000

# Railway Postgres (добавляется автоматически после подключения базы)
DATABASE_URL=

# Telegram Сонастройка
PRACTICE_NOTIFICATIONS_ENABLED=true
PRACTICE_NOTIFICATION_HOURS=24
PRACTICE_FIRST_DELAY_MINUTES=30

# Product flags
DEMO_MODE=true
FREE_CARD_COUNT=3
