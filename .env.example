# Core
NODE_ENV=production
PORT=3000
APP_URL=https://herostar.up.railway.app
SESSION_SECRET=replace-with-a-long-random-string

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Telegram Login Widget
TELEGRAM_BOT_TOKEN=
# Можно оставить пустым: приложение определит username по токену через getMe.
# Если задаёте вручную — без @, например HeroStarBot.
TELEGRAM_BOT_USERNAME=
# Один Telegram ID или несколько через запятую.
TELEGRAM_ADMIN_IDS=

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
FULL_MAP_PRICE=990.00

# Railway Postgres (добавляется автоматически после подключения базы)
DATABASE_URL=

# Product flags
DEMO_MODE=true
FREE_CARD_COUNT=3
